    {
      "parameters": {
        "jsCode": "const raw = ($json.output ?? $json.text ?? '').toString();\nlet text = raw.replace(/\\r\\n/g, '\\n').trim();\nconst maxCharsPerBlob = parseInt($json.maxCharsPerBlob ?? 270, 10);\nconst addNumbering = ($json.addNumbering ?? true) === true;\nif (!text.length) {\n  return [{ json: { blobIndex: 1, blobCount: 1, blobText: '' } }];\n}\nconst limit = Number.isFinite(maxCharsPerBlob) && maxCharsPerBlob > 20 ? maxCharsPerBlob : 270;\nfunction splitByLimitWords(str, chunkLimit) {\n  const words = str.split(/\\s+/);\n  const chunks = [];\n  let cur = '';\n  for (const w of words) {\n    const next = cur ? cur + ' ' + w : w;\n    if (next.length <= chunkLimit) { cur = next; }\n    else {\n      if (cur) chunks.push(cur);\n      if (w.length > chunkLimit) {\n        for (let i = 0; i < w.length; i += chunkLimit) { chunks.push(w.slice(i, i + chunkLimit)); }\n        cur = '';\n      } else { cur = w; }\n    }\n  }\n  if (cur) chunks.push(cur);\n  return chunks;\n}\nlet chunks = splitByLimitWords(text, limit);\nlet blobCount = chunks.length;\nif (addNumbering && blobCount > 1) {\n  const suffixLen = (' (' + blobCount + '/' + blobCount + ')').length;\n  const effectiveLimit = Math.max(20, limit - suffixLen);\n  chunks = splitByLimitWords(text, effectiveLimit);\n  blobCount = chunks.length;\n}\nreturn chunks.map((chunk, idx) => {\n  const i = idx + 1;\n  const suffix = (addNumbering && blobCount > 1) ? (' (' + i + '/' + blobCount + ')') : '';\n  return { json: { blobIndex: i, blobCount, blobText: (chunk + suffix).trim() } };\n});\n"
      },
