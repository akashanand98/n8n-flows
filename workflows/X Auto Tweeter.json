    {
      "parameters": {
        "jsCode": "const tweets = items.map(item => ({\n  id: item.json.id,\n  text: item.json.text.replace(/RT @\\\\w+:/, '').trim()\n}));\n\nconst tweetTexts = tweets.map(t => t.text).join('\\n\\n');\n\nreturn [{ json: { tweetTexts, count: tweets.length, topic: 'Claude Code AI tool' } }];\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
